# Karta Environment Variables
# Copy this file to .env and fill in your keys
# Never commit .env to git!

# =============================================================================
# KARTA CONFIGURATION
# =============================================================================

# Your name (how Karta introduces itself)
PRINCIPAL_NAME=Your Name

# Task for the call (what Karta should accomplish)
TASK=This is a test call to check if the assistant is working.

# =============================================================================
# VOICE ENGINE (choose one)
# =============================================================================

# Google Gemini Live API
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI Realtime API (alternative)
# OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# TELEPHONY PROVIDER (choose one)
# =============================================================================

# --- Twilio (most popular, good docs) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+15550000000

# --- Telnyx (25-45% cheaper, owns infrastructure) ---
# TELNYX_API_KEY=your_telnyx_api_key_here
# TELNYX_PHONE_NUMBER=+15550000000

# --- Vonage (good for WebRTC, per-second billing) ---
# VONAGE_API_KEY=your_vonage_api_key_here
# VONAGE_API_SECRET=your_vonage_api_secret_here
# VONAGE_PHONE_NUMBER=+15550000000

# --- Plivo (30-35% cheaper, good for startups) ---
# PLIVO_AUTH_ID=your_plivo_auth_id_here
# PLIVO_AUTH_TOKEN=your_plivo_auth_token_here
# PLIVO_PHONE_NUMBER=+15550000000
